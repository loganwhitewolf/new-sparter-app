# Copy to .env.local and fill in values.
# Do not commit .env.local.

# Database (MySQL, required from Phase 2)
DATABASE_URL=mysql://user:password@localhost:3306/sparter

# Better Auth (Phase 2)
BETTER_AUTH_SECRET=your-32-char-random-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare R2 (Phase 5)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=sparter-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Staging bypass auth header (all environments)
STAGING_KEY=your-random-bypass-key
