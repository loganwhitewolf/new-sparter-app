# Local development defaults. Copy to .env.local or .env and adjust for your environment.
# Do not commit real credentials, connection strings, or tokens.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local development can use the Docker Postgres URL below.
# Vercel production should use the Supabase runtime connection string configured
# as a secret Vercel runtime variable. Prefer the Supabase pooler URL for app
# runtime traffic when compatible with the deployed app.
DATABASE_URL=postgres://postgres:sparter@localhost:5432/sparter

# Serverless-safe runtime pool size. If omitted or invalid, the app defaults to 2.
# Values above 5 are capped to 5 to protect Vercel/Supabase Free deployments.
# Recommended production value: 2.
# DATABASE_POOL_MAX=2

# Set to true for Supabase production connections when SSL is required.
# Local Docker development usually leaves this unset.
# DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Server-side auth origin. In production, set this to the deployed HTTPS origin.
BETTER_AUTH_URL=http://localhost:3000

# Intentionally public browser-side auth origin. This must be safe to expose.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Secret server-side auth key. Use a long random value outside this example file.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Planned production registration guardrail for M007/S04.
# Documented now for deployment planning; signup blocking is implemented later.
# REGISTRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Cloudflare R2 storage
# -----------------------------------------------------------------------------
# Required for CSV/Excel import file uploads. These are secret server-side Vercel
# runtime variables except the bucket name, which still stays server-side here.
# GET /api/health returns components.r2.ok: false with missing variable names when
# these are absent; it must not print credential values.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional: presigned URL TTL in seconds (default 600 / 10 min, max 3600).
# R2_PRESIGNED_UPLOAD_TTL_SECONDS=600

# -----------------------------------------------------------------------------
# Categorization gates
# -----------------------------------------------------------------------------
# Alpha categorization gates. Defaults are intentionally open during alpha.
# Set any value to basic or pro later to reintroduce plan gates without code changes.
# CATEGORIZATION_REGEX_MIN_PLAN=free
# CATEGORIZATION_HISTORY_MIN_PLAN=free
# CATEGORIZATION_CUSTOM_PATTERNS_MIN_PLAN=free

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Optional: set BETTERSTACK_SOURCE_TOKEN to enable Better Stack log shipping.
# Leave blank to keep structured logs on stdout only; never commit a real token.
BETTERSTACK_SOURCE_TOKEN=

# Optional Better Stack ingest endpoint override; the default endpoint is safe to document.
BETTERSTACK_INGESTING_URL=https://in.logs.betterstack.com
